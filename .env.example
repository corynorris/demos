# demos.corynorris.me — copy to .env and fill in. Do NOT commit .env.
# Run ./scripts/gen-prod-env.sh to generate a production .env with
# auto-generated secrets.

# ===================
# PostgreSQL (shared server — DBs: spaced_repetition, video_api)
# WARNING: POSTGRES_PASSWORD is baked into the volume on first boot.
# Do NOT change it after the first successful deploy.
# ===================
POSTGRES_USER=demos
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# ===================
# URL Shortener
# ===================
# BASE_URL=https://demos.corynorris.me/s

# ===================
# Spaced Repetition (Rust/Axum)
# ===================
# DATABASE_URL=postgres://demos:CHANGE_ME@db:5432/spaced_repetition

# ===================
# Video API (Elixir/Phoenix)
# Generate with: openssl rand -hex 64  (for KEY_BASE)
# Generate with: openssl rand -hex 32  (for SECRET_KEY)
# ===================
# VIDEO_SECRET_KEY_BASE=CHANGE_ME_64_bytes
# VIDEO_SECRET_KEY=CHANGE_ME

# ===================
# Public domain
# ===================
# DOMAIN=demos.corynorris.me
